# Configuración de Supabase para sincronización de base de datos
# Copia este archivo a .env y completa con tus credenciales

# URL de conexión a PostgreSQL de Supabase
# Formato: postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres
DATABASE_URL=postgresql://postgres:tu_password@db.xxxxx.supabase.co:5432/postgres

# Credenciales de Supabase (opcional, para funciones adicionales)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=tu_anon_key_aqui
