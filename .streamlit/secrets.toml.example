# Ejemplo de configuración de secrets para Streamlit Cloud
# Copia este contenido en la sección "Secrets" de tu app en Streamlit Cloud

# Contraseña de acceso a la aplicación
APP_PASSWORD = "TuContraseñaSegura123!"

# API Key de Google Gemini (opcional)
GEMINI_API_KEY = "tu_api_key_de_google_gemini"

# Otras configuraciones opcionales
DEBUG = false
